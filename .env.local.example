# Paste your PayPal Sandbox credentials here (do NOT commit .env.local)
# Leave FORCE_PRODUCTION_VALIDATION unset for normal local development.
# Set it to true only if you want local builds to enforce the same env checks as production.
FORCE_PRODUCTION_VALIDATION=false
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=replace_with_paypal_client_id
PAYPAL_CLIENT_SECRET=replace_with_paypal_client_secret
PAYPAL_WEBHOOK_SECRET=replace_with_paypal_webhook_secret

# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
# Optional but recommended for Prisma migrations, especially on Supabase.
DIRECT_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# Base URL used for return/cancel links in Sandbox (local dev)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
BASE_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000,https://your-store.example.com,https://*.vercel.app

# Admin panel (/admin)
ADMIN_PASSWORD=replace_with_long_admin_password
ADMIN_SESSION_SECRET=replace_with_random_32_byte_secret
DELIVERY_MODE=agent
DELIVERY_AGENT_TOKEN=replace_with_random_32_byte_plugin_token

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-or-TEST-token
MERCADOPAGO_WEBHOOK_SECRET=replace_with_mercadopago_webhook_secret
# Mercado Pago Uruguay charges in UYU. Store prices stay in USD and are converted here.
MERCADOPAGO_CURRENCY_ID=UYU
MERCADOPAGO_UYU_PER_USD=40
# Optional: only needed if you later embed Mercado Pago widgets in the browser.
# NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-or-TEST-public-key

# Minecraft RCON
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=replace_with_rcon_password

# Optional: expose the public client id to the browser (not a secret).
# If omitted, the app will fetch it from `/api/paypal/config`.
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=$PAYPAL_CLIENT_ID
